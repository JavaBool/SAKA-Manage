{
  "openapi": "3.0.0",
  "info": {
    "title": "SAKA-Manage API Documentation",
    "description": "REST APIs documentation for SAKA-Manage customer feedback system.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "Relative API endpoint"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "APIKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Authenticate Manager or Boss",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["username", "password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Successfully logged in, returns JWT token" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/auth/profile": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Retrieve the current authenticated user profile",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "User profile dict" },
          "401": { "description": "Authentication required" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Logout current user (Invalidates/removes push device token)",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Logged out successfully" },
          "401": { "description": "Authentication required" }
        }
      }
    },
    "/admin_auth/login": {
      "post": {
        "tags": ["Admin Authentication"],
        "summary": "Step 1 of Admin Login - Verify credentials and send OTP",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Credentials verified, OTP code sent by email" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/admin_auth/verify-otp": {
      "post": {
        "tags": ["Admin Authentication"],
        "summary": "Step 2 of Admin Login - Verify 6 digit OTP",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "otp": { "type": "string" }
                },
                "required": ["email", "otp"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OTP verified, session created and returns JWT token" },
          "401": { "description": "Invalid or expired OTP" }
        }
      }
    },
    "/users": {
      "get": {
        "tags": ["Users"],
        "summary": "List all personnel logins (Boss/Manager)",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "List of user dicts" }
        }
      },
      "post": {
        "tags": ["Users"],
        "summary": "Create a new personnel login account (Admin only)",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" },
                  "role": { "type": "string", "enum": ["BOSS", "MANAGER"] },
                  "phone": { "type": "string" }
                },
                "required": ["username", "email", "password", "role"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User created" }
        }
      }
    },
    "/users/{user_id}": {
      "get": {
        "tags": ["Users"],
        "summary": "Get a specific user detail",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "user_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "User details" },
          "404": { "description": "User not found" }
        }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Update user details (Admin only)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "user_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "email": { "type": "string" },
                  "role": { "type": "string", "enum": ["BOSS", "MANAGER"] },
                  "phone": { "type": "string" },
                  "active": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "User updated" },
          "404": { "description": "User not found" }
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Delete a user account (Admin only)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "user_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "User deleted" },
          "404": { "description": "User not found" }
        }
      }
    },
    "/contacts": {
      "get": {
        "tags": ["Contacts"],
        "summary": "Get contacts directory (Managers only see assigned, Bosses/Admins see all)",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "List of contacts" }
        }
      },
      "post": {
        "tags": ["Contacts"],
        "summary": "Create a customer contact (Admin only)",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "201": { "description": "Contact created" }
        }
      }
    },
    "/contacts/{contact_id}": {
      "get": {
        "tags": ["Contacts"],
        "summary": "Get contact by ID",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "contact_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Contact details" },
          "404": { "description": "Contact not found" }
        }
      },
      "put": {
        "tags": ["Contacts"],
        "summary": "Update contact details (Admin only)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "contact_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Contact updated" }
        }
      },
      "delete": {
        "tags": ["Contacts"],
        "summary": "Delete contact (Admin only)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "contact_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Contact deleted" }
        }
      }
    },
    "/products": {
      "get": {
        "tags": ["Products"],
        "summary": "List products in portfolio",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "List of products" }
        }
      },
      "post": {
        "tags": ["Products"],
        "summary": "Create a new product catalog item (Admin only)",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "201": { "description": "Product created" }
        }
      }
    },
    "/products/{product_id}": {
      "get": {
        "tags": ["Products"],
        "summary": "Get product by ID",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "product_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Product details" }
        }
      },
      "put": {
        "tags": ["Products"],
        "summary": "Update product details or active state (Admin only)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "product_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Product updated" }
        }
      },
      "delete": {
        "tags": ["Products"],
        "summary": "Delete product (Admin only)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "product_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Product deleted" }
        }
      }
    },
    "/reports": {
      "get": {
        "tags": ["Reports"],
        "summary": "List feedback reports (Managers see own, Bosses/Admins see all)",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "List of reports" }
        }
      },
      "post": {
        "tags": ["Reports"],
        "summary": "Create a new customer feedback report (Manager only) (Supports multipart/form-data files)",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "201": { "description": "Report created" }
        }
      }
    },
    "/reports/{report_id}": {
      "get": {
        "tags": ["Reports"],
        "summary": "Get detailed feedback report by ID",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "report_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Report details" }
        }
      },
      "put": {
        "tags": ["Reports"],
        "summary": "Update feedback report status or priority",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "report_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Report updated successfully" }
        }
      }
    },
    "/reports/export": {
      "get": {
        "tags": ["Reports"],
        "summary": "Export all reports in CSV format (Boss/Admin only)",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "CSV attachment payload" }
        }
      }
    },
    "/followups": {
      "post": {
        "tags": ["Followups"],
        "summary": "Log a followup notes progress entry (Manager only)",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "report_id": { "type": "string", "format": "uuid" },
                  "notes": { "type": "string" }
                },
                "required": ["report_id", "notes"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Followup added" }
        }
      }
    },
    "/notifications": {
      "get": {
        "tags": ["Notifications"],
        "summary": "List current user notifications",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Notifications list" }
        }
      }
    },
    "/notifications/{notification_id}/read": {
      "put": {
        "tags": ["Notifications"],
        "summary": "Mark a notification as read",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "notification_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Notification updated" }
        }
      }
    },
    "/notifications/read-all": {
      "put": {
        "tags": ["Notifications"],
        "summary": "Mark all user notifications as read",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "All notifications marked read" }
        }
      }
    },
    "/analytics": {
      "get": {
        "tags": ["Analytics"],
        "summary": "Retrieve KPI metrics and Chart distributions (Boss/Admin only)",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Analytics calculations JSON" }
        }
      }
    },
    "/analytics/daily-target": {
      "get": {
        "tags": ["Analytics"],
        "summary": "Retrieve the current daily contact target configuration",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Returns current DailyTarget object" }
        }
      },
      "post": {
        "tags": ["Analytics"],
        "summary": "Update the daily target contacts goal (Boss/Admin only)",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "target_contacts": { "type": "integer", "minimum": 1 }
                },
                "required": ["target_contacts"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Returns updated DailyTarget object" },
          "400": { "description": "Invalid parameter" }
        }
      }
    },
    "/analytics/daily-summary": {
      "get": {
        "tags": ["Analytics"],
        "summary": "Retrieve today's unique contacts handled vs target goal and report submissions list",
        "security": [{ "BearerAuth": [] }, { "APIKeyAuth": [] }],
        "responses": {
          "200": { "description": "Returns progress details, target, and today_reports list" }
        }
      }
    },
    "/analytics/send-daily-summary": {
      "post": {
        "tags": ["Analytics"],
        "summary": "Compile today's metrics and broadcast FCM summary notification to all active Bosses",
        "security": [{ "BearerAuth": [] }, { "APIKeyAuth": [] }],
        "responses": {
          "200": { "description": "Summary compiled and dispatched. Returns detailed dispatch_results per boss/device token" }
        }
      }
    },
    "/device_tokens": {
      "post": {
        "tags": ["Push Tokens"],
        "summary": "Register mobile/desktop FCM device token",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "platform": { "type": "string", "enum": ["android", "windows"] },
                  "fcm_token": { "type": "string" }
                },
                "required": ["platform", "fcm_token"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "FCM Token registered" }
        }
      }
    },
    "/test-push": {
      "post": {
        "tags": ["Testing"],
        "summary": "Debug/Test endpoint to send a push notification to any specified token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": { "type": "string" },
                  "title": { "type": "string" },
                  "message": { "type": "string" }
                },
                "required": ["token"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Test push completed" }
        }
      }
    },
    "/test-notification": {
      "post": {
        "tags": ["Testing"],
        "summary": "Debug/Test endpoint to send a test push notification to all device tokens of the currently authenticated user",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "message": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Test notification completed" }
        }
      }
    }
  }
}
