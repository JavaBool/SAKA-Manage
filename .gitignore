# Root .gitignore for SAKA-Manage project

# === Python & Flask ===
backend/venv/
backend/ENV/
backend/__pycache__/
backend/*/__pycache__/
backend/*/*/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/
backend/uploads/*
!backend/uploads/.gitkeep

# === Databases ===
*.db
*.sqlite
instance/
backend/instance/

# === IDE & OS Files ===
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.DS_Store
Thumbs.db

# === Firebase Secrets (Server-Side) ===
# Private service account keys should never be committed to Git!
*serviceAccountKey*.json
*firebase-key*.json
*firebase_key*.json
*firebase-private-key*.json
*private_key*.json
backend/config/serviceAccountKey.json
backend/serviceAccountKey.json
.env
backend/.env

# === Flutter & Dart (Client-Side) ===
# Note: Public Firebase options (like API keys) are typically committed for compiling the client,
# but you can add client_flutter/lib/firebase_options.dart to this list if you want to keep it local.
client_flutter/.dart_tool/
client_flutter/.packages
client_flutter/.flutter-plugins
client_flutter/.flutter-plugins-dependencies
client_flutter/build/
client_flutter/windows/flutter/ephemeral/
client_flutter/android/app/google-services.json
client_flutter/ios/Runner/GoogleService-Info.plist
